# ===========================================================================
# Mundial 2026 - Configuración de entorno (copiar a .env)
# ===========================================================================

# --- App ---
APP_NAME="Mundial 2026 Predictions"
ENVIRONMENT=development           # development | production
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Seguridad ---
SECRET_KEY=change-me-super-secret-key-please-rotate
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Usuario administrador inicial (creado en el primer arranque).
# En Azure define FIRST_ADMIN_PASSWORD como variable de entorno segura.
FIRST_ADMIN_EMAIL=germandres_91@hotmail.com
FIRST_ADMIN_PASSWORD=Mundial2026!
FIRST_ADMIN_NAME=German Andres Bello Garcia

# --- Base de datos ---
# Desarrollo (SQLite)
DATABASE_URL=sqlite:///./data/mundial.db
# Producción (PostgreSQL) - ejemplo:
# DATABASE_URL=postgresql+psycopg2://mundial:mundial@postgres:5432/mundial

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Regex de orígenes permitidos (por defecto cualquier Azure Static Web App)
CORS_ORIGIN_REGEX=https://.*\.azurestaticapps\.net

# --- Proveedor de fútbol ---
# Para usar datos reales del Mundial con football-data.org:
#   FOOTBALL_PROVIDER=football_data
#   FOOTBALL_API_KEY=<tu token de https://www.football-data.org/client/register>
#   FOOTBALL_COMPETITION_ID=WC
FOOTBALL_PROVIDER=mock            # mock | football_data | api_football | worldcup_api
FOOTBALL_API_KEY=
FOOTBALL_API_TIMEOUT=15
FOOTBALL_COMPETITION_ID=WC        # football-data.org usa "WC" para Mundial

# --- Automatización ---
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=5           # 1 request por sync; muy por debajo del límite (10/min)
# Si es false, la sync solo actualiza partidos existentes (no crea ajenos)
SYNC_CREATE_MISSING=false

# --- Excel ---
EXCEL_PREDICTIONS_PATH=./data/predicciones.xlsx
EXCEL_RULES_PATH=./data/reglas_puntaje.xlsx
EXPORTS_DIR=./data/exports

# --- Frontend ---
VITE_API_URL=/api/v1
